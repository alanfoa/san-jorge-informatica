# ── Backend (crear backend/.env) ──
JWT_SECRET=sanjorge-secret-cambiar-en-produccion
CORS_ORIGIN=http://localhost:5173
PORT=3001

# Cloudinary (opcional, para upload de imágenes)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mercado Pago
# Obtener de https://developers.mercadopago.com → Credenciales → Access Token
MERCADOPAGO_ACCESS_TOKEN=

# PostgreSQL (Supabase) — si está definido, reemplaza SQLite
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Frontend (crear frontend/.env) ──
# VITE_API_URL=http://localhost:3001/api
