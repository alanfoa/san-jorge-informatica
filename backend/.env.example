# Copiá este archivo como .env y completá los valores
# JWT_SECRET: generá uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Mercado Pago — https://www.mercadopago.com.ar/developers/panel/app → Credenciales
MERCADOPAGO_ACCESS_TOKEN=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Contraseña del admin (seed). Si no está, usa "Academia01" por defecto.
ADMIN_PASSWORD=

# PostgreSQL (Supabase) — producción persistente
# DATABASE_URL=postgresql://...
