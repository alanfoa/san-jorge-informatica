{
  "name": "sanjorge-backend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start:dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/main.js",
    "seed": "tsx src/seeds/seed.ts",
    "seed:prod": "node dist/seeds/seed.js",
    "sync:prod": "node dist/seeds/import-invid.js",
    "sync": "tsx src/seeds/import-invid.ts",
    "backup:export": "tsx src/seeds/export-catalog.ts",
    "backup:import": "tsx src/seeds/import-backup.ts",
    "setup": "tsx src/seeds/seed.ts && tsx src/seeds/import-invid.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "tsx src/database/data-source.ts run",
    "migration:generate": "tsx src/database/data-source.ts generate",
    "migration:revert": "tsx src/database/data-source.ts revert",
    "migration:show": "tsx src/database/data-source.ts show"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.3.0",
    "compression": "^1.8.1",
    "mercadopago": "^3.0.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sql.js": "^1.14.1",
    "typeorm": "^0.3.29"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.12",
    "@types/passport-jwt": "^4.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
